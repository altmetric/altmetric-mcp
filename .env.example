# Contact Altmetric for API credentials

# Details Page API Configuration (required for Details Page API tools)
ALTMETRIC_DETAILS_API_KEY=your_details_api_key_here

# Explorer API Configuration (required for Explorer API tools)
ALTMETRIC_EXPLORER_API_KEY=your_explorer_api_key_here
ALTMETRIC_EXPLORER_API_SECRET=your_explorer_api_secret_here

# HTTP transport (OAuth) - only for `npm run start:http`; not used by the stdio entrypoint.
# Credentials are brokered per request from the caller's OAuth bearer, so no API keys here.
# PORT=3000
# HOST=127.0.0.1
# EXPLORER_BASE_URL=https://www.altmetric.com
# MCP_PUBLIC_URL=http://127.0.0.1:3000
